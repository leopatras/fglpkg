#!/bin/sh
#fglpkg-genero: self-compiling launcher for the published "fglpkg" source
#package (the Genero 4GL reimplementation of the fglpkg tool). One
#published artifact works across Genero majors without shipping .42m
#bytecode (which is not compatible across majors) -- separate from the
#real g/fglpkg/fglpkg development launcher in the source repo, which
#execs a precompiled main.42m directly.
#
#Compiles straight from the installed package's own source directory
#($dir) into a per-Genero-version cache dir under $TMPDIR, via fglcomp's
#--output-dir (-o) combined with --make -- no copy step needed at all:
#fglcomp reads sources from $dir directly and only writes/checks .42m
#under the cache dir, so `--make`'s staleness check (source newer than
#its .42m?) always sees the real, live install directory, including
#after the installed package itself gets updated. Verified this really
#does per-module dependency-aware incremental compilation (touching one
#source file only recompiles it plus its actual dependents, not
#everything) -- not documented with a worked example combining --make
#with -o, so don't take this combination for granted elsewhere without
#checking again.
#
#fglcomp treats PACKAGE fglpkg modules specially: given -o <dir>, it
#creates <dir>/fglpkg/ itself (mirroring the package name) and writes
#.42m there -- so this must run from the cache dir's PARENT (which must
#NOT itself be named "fglpkg"), not from the "fglpkg" dir itself, or you
#get a doubly-nested fglpkg/fglpkg/.
#FGL_LENGTH_SEMANTICS=CHAR is required: fglpkgutils.cmpBytes (and any
#other per-character loop) relies on ORD() resolving full Unicode code
#points, not just the first byte of a multi-byte UTF-8 character.
dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
FGL_LENGTH_SEMANTICS=CHAR
export FGL_LENGTH_SEMANTICS

#"fglcomp 6.00.02 rev-5054478" -> "6.00" (major.minor only -- .42m
#compatibility is a major.minor concern, not a patch-level one)
ver=$(fglcomp -V 2>&1 | head -n 1 | awk '{print $2}')
majmin=$(echo "$ver" | cut -d. -f1,2)
if [ -z "$majmin" ]; then
  echo "fglpkg-genero: could not determine the Genero version (fglcomp -V failed)" >&2
  exit 1
fi

tmpbase=${TMPDIR:-/tmp}
cachebase="$tmpbase/fglpkg-$majmin"
mkdir -p "$cachebase" || exit 1

FGLLDPATH="$cachebase${FGLLDPATH:+:$FGLLDPATH}"
export FGLLDPATH

( cd "$cachebase" && fglcomp --make -o . "$dir"/*.4gl ) >&2 || exit 1
exec fglrun "$cachebase/fglpkg/main.42m" "$@"
